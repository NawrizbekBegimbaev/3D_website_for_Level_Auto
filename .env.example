# Copy to .env.local for local development (`npm run dev`). Gitignored.
# On Vercel these live in Project → Settings → Environment Variables.

# From @BotFather -> /newbot
TELEGRAM_BOT_TOKEN="123456789:AA..."

# Where the leads land. Personal chat: write to your bot once, then open
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# and copy result[].message.chat.id  (a group id looks like -1001234567890).
TELEGRAM_CHAT_ID="-1001234567890"
